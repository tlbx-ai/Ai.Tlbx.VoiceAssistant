    // --- Push-to-talk: local record → REST API ---

    private async Task OnPushToTalkDown()
    {
        if (_isPttRecording || _isPttProcessing) return;
        if (voiceAssistant?.IsRecording ?? false) return;

        _isPttRecording = true;

        try
        {
            // Clear buffer from any previous run
            while (_pttAudioChunks.TryDequeue(out _)) { }

            await HardwareAccess.InitAudioAsync();
            var started = await HardwareAccess.StartRecordingAudio(
                (sender, e) => _pttAudioChunks.Enqueue(e.Base64EncodedPcm16Audio),
                AudioSampleRate.Rate24000);

            if (!started)
            {
                _isPttRecording = false;
                Log(LogLevel.Error, "Failed to start PTT recording");
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _isPttRecording = false;
            Log(LogLevel.Error, $"PTT start error: {ex.Message}");
        }
    }

    private async Task OnPushToTalkUp()
    {
        if (!_isPttRecording) return;

        _isPttRecording = false;

        try
        {
            await HardwareAccess.StopRecordingAudio();

            if (_pttAudioChunks.IsEmpty)
            {
                await InvokeAsync(StateHasChanged);
                return;
            }

            _isPttProcessing = true;
            await InvokeAsync(StateHasChanged);

            var pcmBytes = DrainPttBuffer();
            var wavBytes = BuildWav(pcmBytes, 24000);

            Log(LogLevel.Info, $"Sending {wavBytes.Length / 1024}KB WAV to REST API...");
            var text = await TranscribeViaRestAsync(wavBytes);

            if (!string.IsNullOrWhiteSpace(text))
            {
                _transcriptionFullText += text + "\n";
            }
        }
        catch (Exception ex)
        {
            Log(LogLevel.Error, $"PTT transcribe error: {ex.Message}");
        }
        finally
        {
            _isPttProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private byte[] DrainPttBuffer()
    {
        using var ms = new MemoryStream();
        while (_pttAudioChunks.TryDequeue(out var chunk))
        {
            var bytes = Convert.FromBase64String(chunk);
            ms.Write(bytes, 0, bytes.Length);
        }
        return ms.ToArray();
    }

    private static byte[] BuildWav(byte[] pcmData, int sampleRate)
    {
        const int channels = 1;
        const int bitsPerSample = 16;
        int byteRate = sampleRate * channels * bitsPerSample / 8;
        int blockAlign = channels * bitsPerSample / 8;

        using var ms = new MemoryStream(44 + pcmData.Length);
        using var w = new BinaryWriter(ms);

        w.Write(new[] { (byte)'R', (byte)'I', (byte)'F', (byte)'F' });
        w.Write(36 + pcmData.Length);
        w.Write(new[] { (byte)'W', (byte)'A', (byte)'V', (byte)'E' });

        w.Write(new[] { (byte)'f', (byte)'m', (byte)'t', (byte)' ' });
        w.Write(16);
        w.Write((short)1);
        w.Write((short)channels);
        w.Write(sampleRate);
        w.Write(byteRate);
        w.Write((short)blockAlign);
        w.Write((short)bitsPerSample);

        w.Write(new[] { (byte)'d', (byte)'a', (byte)'t', (byte)'a' });
        w.Write(pcmData.Length);
        w.Write(pcmData);

        return ms.ToArray();
    }

    private async Task<string> TranscribeViaRestAsync(byte[] wavAudio)
    {
        var apiKey = Environment.GetEnvironmentVariable("OPENAI_API_KEY")
            ?? throw new InvalidOperationException("OPENAI_API_KEY not set");

        if (!Enum.TryParse<OpenAiTranscriptionModel>(_transcriptionModelString, out var model))
            model = OpenAiTranscriptionModel.Gpt4oMiniTranscribe;

        using var client = new HttpClient();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", apiKey);

        using var form = new MultipartFormDataContent();
        var audioContent = new ByteArrayContent(wavAudio);
        audioContent.Headers.ContentType = new MediaTypeHeaderValue("audio/wav");
        form.Add(audioContent, "file", "audio.wav");
        form.Add(new StringContent(model.ToApiString()), "model");
        form.Add(new StringContent("de"), "language");
        form.Add(new StringContent("Expect German with slight accent, business/IT/construction terms"), "prompt");

        var response = await client.PostAsync("https://api.openai.com/v1/audio/transcriptions", form);
        var body = await response.Content.ReadAsStringAsync();

        if (!response.IsSuccessStatusCode)
        {
            Log(LogLevel.Error, $"REST transcription failed: {response.StatusCode} - {body}");
            return string.Empty;
        }

        using var doc = JsonDocument.Parse(body);
        return doc.RootElement.GetProperty("text").GetString() ?? "";
    }

