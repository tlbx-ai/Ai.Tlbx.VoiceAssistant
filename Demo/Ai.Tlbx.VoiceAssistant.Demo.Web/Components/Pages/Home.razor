    // --- Push-to-talk: near-live HTTP transcription ---

    private async Task OnPushToTalkDown()
    {
        if (_isPttRecording || _isPttProcessing) return;
        if (voiceAssistant?.IsRecording ?? false) return;

        _isPttRecording = true;
        _pttReceivedText = false;
        _pttLiveHypothesisText = string.Empty;

        try
        {
            await StopPttLiveTranscriptionAsync();

            _pttLiveTranscriptionCts = new CancellationTokenSource();
            _pttLiveTranscriber = new OpenAiHttpLiveTranscriber(
                HardwareAccess,
                BuildPttLiveTranscriptionOptions(),
                logAction: Log);

            _pttLiveTranscriptionTask = _pttLiveTranscriber.TranscribeLive(
                OnPttLiveTextChunk,
                _pttLiveTranscriptionCts.Token);

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _isPttRecording = false;
            Log(LogLevel.Error, $"PTT start error: {ex.Message}");
            await StopPttLiveTranscriptionAsync();
        }
    }

    private async Task OnPushToTalkUp()
    {
        if (!_isPttRecording) return;

        _isPttRecording = false;

        try
        {
            _isPttProcessing = true;
            await InvokeAsync(StateHasChanged);

            await StopPttLiveTranscriptionAsync();

            if (_pttReceivedText && !string.IsNullOrWhiteSpace(_pttLiveHypothesisText))
            {
                if (_transcriptionCommittedText.Length > 0 &&
                    !_transcriptionCommittedText.EndsWith("\n", StringComparison.Ordinal))
                {
                    _transcriptionCommittedText += "\n";
                }

                _transcriptionCommittedText += _pttLiveHypothesisText + "\n";
            }

            _pttLiveHypothesisText = string.Empty;
        }
        catch (Exception ex)
        {
            Log(LogLevel.Error, $"PTT transcribe error: {ex.Message}");
        }
        finally
        {
            _isPttProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private OpenAiHttpLiveTranscriptionOptions BuildPttLiveTranscriptionOptions()
    {
        if (!Enum.TryParse<OpenAiTranscriptionModel>(_transcriptionModelString, out var model))
            model = OpenAiTranscriptionModel.Gpt4oMiniTranscribe;

        return new OpenAiHttpLiveTranscriptionOptions
        {
            TranscriptionModel = model,
            Language = "de",
            Prompt = "Expect German with slight accent, business/IT/construction terms",
            SnapshotInterval = TimeSpan.FromMilliseconds(250),
            MinimumUtteranceDuration = TimeSpan.FromMilliseconds(120),
            LeadingTrimDuration = TimeSpan.FromMilliseconds(120),
            PrefixPadding = TimeSpan.FromMilliseconds(250),
            SilenceDuration = TimeSpan.FromMilliseconds(180),
            VadThreshold = 0.28
        };
    }

    private void OnPttLiveTextChunk(string transcript)
    {
        InvokeAsync(() =>
        {
            _pttLiveHypothesisText = transcript;
            _pttReceivedText = transcript.Length > 0;
            StateHasChanged();
        });
    }

    private async Task StopPttLiveTranscriptionAsync()
    {
        var transcriber = _pttLiveTranscriber;
        var liveTask = _pttLiveTranscriptionTask;
        var cts = _pttLiveTranscriptionCts;

        _pttLiveTranscriber = null;
        _pttLiveTranscriptionTask = null;
        _pttLiveTranscriptionCts = null;

        try
        {
            cts?.Cancel();

            if (transcriber != null)
            {
                await transcriber.StopAsync();
            }

            if (liveTask != null)
            {
                await liveTask;
            }
        }
        finally
        {
            cts?.Dispose();

            if (transcriber != null)
            {
                await transcriber.DisposeAsync();
            }
        }
    }

    private void ClearTranscriptionText()
    {
        _transcriptionCommittedText = string.Empty;
        _pttLiveHypothesisText = string.Empty;
    }

    private void OnTranscriptionModelChanged(ChangeEventArgs e)
    {
        _transcriptionModelString = e.Value?.ToString() ?? _transcriptionModelString;
        Log(LogLevel.Info, $"Transcription model changed to: {_transcriptionModelString}");
    }

    public async ValueTask DisposeAsync()
    {
        await StopPttLiveTranscriptionAsync();

        if (voiceAssistant != null)
        {
            voiceAssistant.OnConnectionStatusChanged = null;
            voiceAssistant.OnMessageAdded = null;
            voiceAssistant.OnMicrophoneDevicesChanged = null;
            voiceAssistant.OnTranscriptionDelta = null;
            voiceAssistant.OnTranscriptionCompleted = null;
            await voiceAssistant.DisposeAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Add JS helper function for scrolling
            await JS.InvokeVoidAsync("eval", @"
                window.scrollToBottom = function(element) {
                    if (element) {
                        element.scrollTop = element.scrollHeight;
                    }
                }
            ");

            // Check microphone permission state without activating microphone
            await CheckMicrophonePermissionState();
        }
    }

    // Helper function to format JSON for display
    private string FormatJson(string? jsonString)
    {
        if (string.IsNullOrWhiteSpace(jsonString))
        {    
            return "(empty)";
        }
        try
        {
            using var jsonDoc = System.Text.Json.JsonDocument.Parse(jsonString);
            return System.Text.Json.JsonSerializer.Serialize(jsonDoc, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch (System.Text.Json.JsonException)
        {
            // If it's not valid JSON, return the original string
            return jsonString;
        }
        catch (Exception ex)
        {
            return $"Error formatting JSON: {ex.Message}";
        }
    }

    // Helper function to truncate text
    private string TruncateText(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
            
        return text.Substring(0, maxLength) + "...";
    }
