    private static List<TEnum> GetSelectableEnumValues<TEnum>() where TEnum : struct, Enum
    {
        return Enum.GetValues<TEnum>()
            .Where(value =>
            {
                var field = typeof(TEnum).GetField(value.ToString());
                return field is not null && !Attribute.IsDefined(field, typeof(ObsoleteAttribute));
            })
            .ToList();
    }

    private static List<ModelOption> GetEnumOptions<TEnum>(bool includeObsolete = false) where TEnum : struct, Enum
    {
        return Enum.GetValues<TEnum>()
            .Select(value =>
            {
                var field = typeof(TEnum).GetField(value.ToString());
                var obsoleteAttribute = field?.GetCustomAttributes(typeof(ObsoleteAttribute), false).OfType<ObsoleteAttribute>().FirstOrDefault();
                var isObsolete = obsoleteAttribute is not null;

                return new
                {
                    Value = value.ToString(),
                    IsObsolete = isObsolete,
                    Label = isObsolete ? $"{value} [obsolete]" : value.ToString()
                };
            })
            .Where(option => includeObsolete || !option.IsObsolete)
            .Select(option => new ModelOption(option.Value, option.Label))
            .ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        // Create initial VoiceAssistant with OpenAI provider
        RecreateVoiceAssistant();

        // Get all registered tools from DI
        availableTools = ServiceProvider.GetServices<IVoiceTool>().ToList();
        Log(LogLevel.Info, $"Found {availableTools.Count} available tools: {string.Join(", ", availableTools.Select(t => t.Name))}");

        // Enable all tools by default
        enabledTools = availableTools.ToList();

        await Task.CompletedTask;
    }

    private void RecreateVoiceAssistant()
    {
        // Dispose old instance if exists
        if (voiceAssistant != null)
        {
            voiceAssistant.OnConnectionStatusChanged = null;
            voiceAssistant.OnMessageAdded = null;
            voiceAssistant.OnMicrophoneDevicesChanged = null;
        }

        // Create provider based on active tab
        VoiceProviderType providerType;
        if (_activeTab == "transcribe")
        {
            providerType = VoiceProviderType.OpenAiTranscription;
        }
        else
        {
            providerType = _selectedProviderString switch
            {
                "OpenAI" => VoiceProviderType.OpenAI,
                "Google" => VoiceProviderType.Google,
                "xAI" => VoiceProviderType.XAi,
                _ => VoiceProviderType.OpenAI
            };
        }
        var provider = ProviderFactory.CreateProvider(providerType);

        // Create new VoiceAssistant
        voiceAssistant = new VoiceAssistant(HardwareAccess, provider, LogAction);

        // Wire up callbacks
        voiceAssistant.OnConnectionStatusChanged = OnConnectionStatusChanged;
        voiceAssistant.OnMessageAdded = OnMessageAdded;
        voiceAssistant.OnMicrophoneDevicesChanged = OnMicrophoneDevicesChanged;
        voiceAssistant.OnTranscriptionDelta = OnTranscriptionDelta;
        voiceAssistant.OnTranscriptionCompleted = OnTranscriptionCompleted;

        Log(LogLevel.Info, $"Voice Assistant recreated with {_selectedProviderString} provider");
    }

