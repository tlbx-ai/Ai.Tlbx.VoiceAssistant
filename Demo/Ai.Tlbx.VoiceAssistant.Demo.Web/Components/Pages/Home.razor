    private void OnGoogleThinkingLevelChanged(ChangeEventArgs e)
    {
        SessionThinkingLevel? level = null;
        var rawValue = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(rawValue) &&
            Enum.TryParse<SessionThinkingLevel>(rawValue, out var parsedLevel))
        {
            level = parsedLevel;
        }

        sessionSettings = sessionSettings with
        {
            Thinking = sessionSettings.Thinking with { Level = level }
        };
    }

    private void OnGoogleThinkingBudgetChanged(ChangeEventArgs e)
    {
        int? budget = null;
        var rawValue = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(rawValue) &&
            int.TryParse(rawValue, out var parsedBudget) &&
            parsedBudget >= -1)
        {
            budget = parsedBudget;
        }

        sessionSettings = sessionSettings with
        {
            Thinking = sessionSettings.Thinking with { Budget = budget }
        };
    }

    private void OnGoogleIncludeThoughtsChanged(ChangeEventArgs e)
    {
        var includeThoughts = e.Value is bool boolValue
            ? boolValue
            : string.Equals(e.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);

        sessionSettings = sessionSettings with
        {
            Thinking = sessionSettings.Thinking with { IncludeThoughts = includeThoughts }
        };
    }

