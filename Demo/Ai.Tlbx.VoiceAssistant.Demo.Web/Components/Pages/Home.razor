    private async Task OnTabChanged(string tab)
    {
        if (_isBusy || _activeTab == tab) return;

        try { await StopPttLiveTranscriptionAsync(); }
        catch (Exception ex) { Log(LogLevel.Error, $"Error stopping PTT live transcription on tab switch: {ex.Message}"); }

        // Stop old VoiceAssistant before switching (frees audio device + WebSocket)
        if (voiceAssistant != null && (voiceAssistant.IsRecording || voiceAssistant.IsProviderConnected))
        {
            try { await voiceAssistant.StopAsync(); }
            catch (Exception ex) { Log(LogLevel.Error, $"Error stopping on tab switch: {ex.Message}"); }
        }

        _activeTab = tab;
        RecreateVoiceAssistant();
        Log(LogLevel.Info, $"Switched to tab: {tab}");
    }

    private async Task ToggleTranscription()
