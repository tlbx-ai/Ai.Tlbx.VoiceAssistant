            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Log(LogLevel.Error, $"Error stopping session: {ex.Message}");
            Log(LogLevel.Error, $"Stack trace: {ex.StackTrace}");
        }
    }    

